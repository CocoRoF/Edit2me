# 환경 변수 — Edit2me는 자체 .env 파일을 두지 않는다.
# 모든 설정은 호스트(docker-compose 등)가 environment:로 주입한다.
# 그래도 standalone 로컬 dev 시 실수로 만든 .env 파일이 커밋되지 않게 ignore.
.env
.env.*

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# 로그
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# 테스트 / 커버리지
coverage/
.nyc_output/

# 테스트 코퍼스 (큰 PDF는 외부)
tests/corpus/large/
tests/corpus/medium/
tests/corpus/external/
*.pdf
!tests/corpus/small/*.pdf
!frontend/public/samples/*.pdf

# 빌드 산출물
*.tsbuildinfo
next-env.d.ts

# 기타
tmp/
.tmp/
